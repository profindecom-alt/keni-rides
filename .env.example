# Keni Rides — n8n webhook URLs
# Copy this file to .env.local and fill in your real n8n webhook URL(s).
# These must be NEXT_PUBLIC_ because forms POST to them directly from the browser.
#
# Both forms POST to a single n8n endpoint; the workflow branches on the
# payload's `type` field ("booking" or "contact"). Point both vars at the
# same URL (or split them if you later create separate webhooks).

NEXT_PUBLIC_BOOKING_WEBHOOK_URL=https://n8n.srv1019025.hstgr.cloud/webhook/keni-rides-forms
NEXT_PUBLIC_CONTACT_WEBHOOK_URL=https://n8n.srv1019025.hstgr.cloud/webhook/keni-rides-forms
